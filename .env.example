# Copy this file to .env.local and fill in real values.
# Never commit .env or .env.local.

GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model used by all scripts.
# GEMINI_MODEL=gemini-3-pro-preview

# Optional: authenticate YouTube downloads with a Netscape-format cookies.txt file.
# YTDLP_COOKIE_FILE=C:\\Users\\DELL\\Downloads\\www.youtube.com_cookies.txt

# Optional: or load YouTube cookies directly from a browser profile.
# YTDLP_COOKIES_FROM_BROWSER=chrome:Profile 2

# Optional: set this when ffmpeg is not in PATH.
# FFMPEG_BIN=C:\\ffmpeg\\bin\\ffmpeg.exe
